{
  "name": "problemfinder-be",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:staging": "cross-env NODE_ENV=staging node dist/index.js",
    "dev:migrate": "cross-env NODE_ENV=development npx prisma migrate dev",
    "dev:migrate:create": "cross-env NODE_ENV=development ts-node scripts/create-migration.ts",
    "dev:migrate:deploy": "cross-env NODE_ENV=development npx prisma migrate deploy",
    "dev:studio": "cross-env NODE_ENV=development npx prisma studio",
    "staging:migrate": "cross-env NODE_ENV=staging npx prisma migrate dev",
    "staging:migrate:create": "cross-env NODE_ENV=staging ts-node scripts/create-migration.ts",
    "staging:migrate:deploy": "cross-env NODE_ENV=staging npx prisma migrate deploy",
    "production:migrate": "cross-env NODE_ENV=production npx prisma migrate dev",
    "production:migrate:create": "cross-env NODE_ENV=production ts-node scripts/create-migration.ts",
    "production:migrate:deploy": "cross-env NODE_ENV=production npx prisma migrate deploy",
    "postinstall": "npx prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@types/morgan": "^1.9.10",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "prisma": "^7.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
